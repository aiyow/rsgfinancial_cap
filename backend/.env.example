# Server configuration
PORT=5000

# PostgreSQL local database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rsg_condo
DB_USER=postgres
DB_PASSWORD=replace_with_your_postgres_password

# Neon hosted PostgreSQL (use this instead of the local DB_* values when deployed)
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT.neon.tech/neondb?sslmode=require
# DB_SSL=true

# Authentication
JWT_SECRET=replace_with_a_long_random_secret

# Initial Admin and Collector accounts used by `npm run seed`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace_with_a_strong_password
SEED_COLLECTOR_EMAIL=collector@example.com
SEED_COLLECTOR_PASSWORD=replace_with_a_strong_password

# Frontend URL
CLIENT_URL=http://localhost:5173

# Resend is recommended for deployed environments because it sends email over HTTPS.
# Create an API key at https://resend.com/api-keys and verify a sender domain for production.
# RESEND_API_KEY=re_replace_with_your_resend_api_key
# RESEND_FROM="RSG Condo <onboarding@resend.dev>"

# SMTP email notifications are kept as a local-development fallback.
# SMTP_SECURE=true is usually used with port 465; use false for STARTTLS/port 587.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_your_smtp_username
SMTP_PASSWORD=replace_with_your_smtp_password
SMTP_FROM="RSG Condo Billing <billing@example.com>"

# Private Cloudinary payment-receipt storage. Keep these backend-only.
CLOUDINARY_CLOUD_NAME=replace_with_your_cloud_name
CLOUDINARY_API_KEY=replace_with_your_api_key
CLOUDINARY_API_SECRET=replace_with_your_api_secret
CLOUDINARY_RECEIPTS_FOLDER=rsg-condo/payment-receipts
